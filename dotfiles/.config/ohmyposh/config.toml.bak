# Some usefull characters: в•ӯв”Җ в•°в”Җ в”Җв•® в”Җв•Ҝ вңҳ вң” пҢғ  пҖ•  пҒј  п„“  п„Ұ  пҮ“  пү’ 

version = 2
final_space = true
# console_title_template = '{{ .Shell }} in {{ .Folder }}'

[[blocks]]
  type = 'prompt'
  alignment = 'left'
  newline = true

  [[blocks.segments]]
    type = 'path'
    style = 'plain'
    background = 'transparent'
    foreground = 'p:red'
    template = '{{ .Path }}'

    [blocks.segments.properties]
      style = 'full'
      # home_icon = 'пҖ• '
      mapped_locations_enabled = true
      [blocks.segments.properties.mapped_locations]
        '~/' = 'пҢғ ~'

  [[blocks.segments]]
    type = 'git'
    style = 'plain'
    background = 'transparent'
    foreground = 'p:grey'
    templates = [
      ' - ',
      '{{ url .UpstreamIcon .UpstreamURL }}{{.HEAD}}',
      '{{ if or (.Working.Changed) (.Staging.Changed) }}*{{end}}',
      ' {{ .Staging.String }}',
      ' {{if gt .Behind 0}}пҝ¬i{{end}}{{if gt .Ahead 0}}пҝӘ{{end}}',
      '{{if .LatestTag }} пҗ’ {{ .LatestTag }}{{end}}'
    ] 

    [blocks.segments.properties]
      fetch_status = true
      fetch_upstream_icon = true
      branch_icon = 'п„Ұ '
      commit_icon = '@'

[[blocks]]
  type = 'prompt'
  alignment = 'right'

  [[blocks.segments]]
    type = 'executiontime'
    style = 'plain'
    background = 'transparent'
    foreground = 'cyan'
    template = '<p:grey><i>took</i></> {{.FormattedMs}} '

    [blocks.segments.properties]
      style = 'round'
      threshold = 9000
  
  [[blocks.segments]]
    type = 'status'
    style = 'plain'
    background = 'transparent'
    foreground = 'p:red'
    template = '<p:grey>-</> {{if .Error}}{{.String}}{{end}}'


[[blocks]]
  type = 'prompt'
  alignment = 'left'
  newline = true

  [[blocks.segments]]
    type = 'text'
    style = 'plain'
    background = 'transparent'
    foreground = 'p:blue'
    template = 'вҰ’'

[[blocks]]
  type = 'rprompt'

  [[blocks.segments]]
    type = 'status'
    style = 'plain'
    background = 'transparent'
    foreground = 'p:red'
    template = '{{if .Error}}{{ reason .Code }}{{end}}'


# [[tooltips]]
  # type = 'git'
  # tips = [ 'git', 'g' ]
  # style = 'plain'
  # background = 'transparent'
  # foreground = 'p:orange'
  #


[secondary_prompt]
  background = 'transparent'
  foreground = 'p:blue'
  template = 'вҰ’вҰ’'


[transient_prompt]
  background = 'transparent'
  foreground_templates = [
    "{{if eq .Code 0}}p:blue{{end}}",
    "{{if gt .Code 0}}p:red{{end}}",
  ]
  template = "{{ if gt .Code 0}}вӨ· {{ .Code }}\n{{end}}<p:blue>вҰ’</>"


[palette]
  black = '#262B44'
  blue = '#4B95E9'
  green = '#59C9A5'
  orange = '#F07623'
  red = '#D81E5B'
  white = '#E0DEF4'
  yellow = '#F3AE35'
  grey = '#6C6C6C'
